# Vite injeta VITE_* no build (valores públicos — NUNCA segredos aqui).
# Em produção, o build por ambiente define VITE_API_URL a partir de vars.VITE_API_URL (GitHub Environment).
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_ENV=dev
# Metadados públicos exibidos no modal "Sobre o t2c_data" (fallbacks no código se ausentes):
VITE_APP_VERSION=v1.0.0
VITE_APP_DEPLOYED_AT=Julho de 2026
# VITE_APP_COMMIT= (opcional — injetado no build pela CI, ex.: ${GITHUB_SHA::7})
